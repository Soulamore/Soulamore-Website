sort_pdfs.py

# Python caches / model artifacts
__pycache__/
.ipynb_checkpoints/
*.pyc
*.pyo
*.pyd
*.bin
*.safetensors
*.pth
*.weights
*.ckpt
*.h5
*.onnx

