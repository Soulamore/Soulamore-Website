# Soulamore .gitignore

# Node / package managers
node_modules/
.npm/
.eslintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
logs/

# Firebase / local runtime
.firebase/
firebase-debug.log
firestore-debug.log
.dataconnect/

# Build / coverage / temp
coverage/
.nyc_output/
lib-cov/
build/
dist/
tmp/
*.pid
*.pid.lock
*.seed

# Environment / secrets
.env
.env.*

# OS / editor noise
Thumbs.db
desktop.ini
.vscode/
.qoder/

# AI / agent output not meant for version control
Claude Result/
claude_handoff_profiles/
soulbot/Claude results/
soulbot/CLAuse Results 2/
soulbot/Claude Results 2/

# Third-party bundled resources not owned by this repo
Git Tools Open Source/

# Local knowledge base / downloaded source material
knowledge source/
Press and Media Kit/
trademark filing/

# Backups and generated batches
_BACKUPS/
assets/data/assessments/generated_batch.json

# Local model / dataset artifacts
soulbot/models/
soulbot/data/training_dataset.json
soulbot/data/training_raw.json

# One-off debug / audit artifacts
.cursorrules
audit_results.txt
diff.txt
full_diff.txt
header_restoration_log.md
debug.js
debug_nesting.js
extract_debug.js
audit_site.js
audit_shell.js
mock_env.js
generate_logo_js.js
soulbot-animation.js
sync_news.bat
start_server.bat

# Temporary root-level python utilities created during audits / downloads
cleanup_script.py
fix_header.py
fix_links.py
validate_css.py
smart_news_rituals.py
download_pdfs.py
download_safety_docs.py
download_safety_v2.py
download_compliance_docs.py
download_more_knowledge.py
download_indian_context.py
download_verified_indian.py
